{
  "name": "blackbelt-monorepo",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS platform for martial arts academy management",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @blackbelt/web dev",
    "dev:site": "pnpm --filter @blackbelt/site dev",
    "build": "pnpm --filter @blackbelt/web build",
    "build:site": "pnpm --filter @blackbelt/site build",
    "build:all": "pnpm --filter @blackbelt/web build && pnpm --filter @blackbelt/site build",
    "typecheck": "pnpm --filter @blackbelt/web typecheck",
    "typecheck:all": "pnpm -r typecheck",
    "lint": "pnpm --filter @blackbelt/web lint",
    "test": "pnpm --filter @blackbelt/web test",
    "clean": "rm -rf apps/web/.next apps/site/.next node_modules"
  },
  "keywords": [],
  "author": "Gregory Goncalves Silveira Pinto",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2"
}
