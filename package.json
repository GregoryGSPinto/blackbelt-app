{
  "name": "black_belt_v2",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS platform for martial arts academy management",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:mobile": "NEXT_PUBLIC_PLATFORM=mobile next build && node scripts/prepare-capacitor-web.mjs",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "mobile:build": "NEXT_PUBLIC_CAPACITOR=true next build",
    "mobile:sync": "npx cap sync",
    "mobile:ios": "pnpm build:mobile && pnpm cap:sync && pnpm cap:ios",
    "mobile:android": "pnpm build:mobile && pnpm cap:sync && pnpm cap:android",
    "mobile:prepare": "pnpm mobile:build && pnpm mobile:sync",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:e2e:report": "playwright show-report e2e/report",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": "Gregory Goncalves Silveira Pinto",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "supabase": "^2.78.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^7.2.0",
    "@capacitor/android": "^7.6.1",
    "@capacitor/app": "^7.1.0",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/camera": "^7.0.2",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/clipboard": "7.0.1",
    "@capacitor/core": "^7.6.1",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/ios": "^7.6.1",
    "@capacitor/keyboard": "^7.0.1",
    "@capacitor/network": "7.0.1",
    "@capacitor/preferences": "7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "@capacitor/share": "7.0.1",
    "@capacitor/splash-screen": "7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@capacitor/toast": "7.0.1",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "html2pdf.js": "^0.14.0",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "next": "^14.2.35",
