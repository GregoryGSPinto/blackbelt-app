# BlackBelt authenticated product
# Copy to .env.local for local development.

# Public client-safe app surfaces
NEXT_PUBLIC_USE_MOCK=true
NEXT_PUBLIC_SITE_URL=https://blackbeltv2.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_PLATFORM=web
NEXT_PUBLIC_SUPPORT_EMAIL=gregoryguimaraes12@gmail.com
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_BETA_MODE=true
NEXT_PUBLIC_ENABLE_GA=false
NEXT_PUBLIC_ENABLE_POSTHOG=false
NEXT_PUBLIC_ENABLE_RUNTIME_TELEMETRY=false

# Public auth surface + server auth/backend
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
# Server only
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public client-safe
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Mobile companion
# Public client-safe
CAPACITOR_REMOTE_RUNTIME=false
CAPACITOR_STATIC_EXPORT=false
IOS_BUNDLE_ID=app.blackbelt.academy
ANDROID_APPLICATION_ID=app.blackbelt.academy
# Server or local release tooling only
APPLE_DEVELOPMENT_TEAM=
ANDROID_RELEASE_SHA256=
APNS_KEY_ID=
APNS_TEAM_ID=
FCM_SERVER_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Server only
VAPID_PRIVATE_KEY=

# Billing and external channels
# Server only unless explicitly prefixed with NEXT_PUBLIC_
PAYMENT_GATEWAY=mock
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_SANDBOX=true
ASAAS_WEBHOOK_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=default

# Email and notifications
# Server only
EMAIL_PROVIDER=mock
EMAIL_API_KEY=
EMAIL_FROM=gregoryguimaraes12@gmail.com
RESEND_API_KEY=
RESEND_DOMAIN=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Observability and analytics
# NEXT_PUBLIC_* keys are client-safe. The rest stay server-only.
LOG_LEVEL=info
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=blackbelt
SENTRY_PROJECT=blackbelt
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
