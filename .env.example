# BlackBelt v2 -- Environment Variables
# Copy this file to .env.local and fill in the values.
# In mock mode, only NEXT_PUBLIC_USE_MOCK=true is required.

# ── App ──────────────────────────────────────────────
NEXT_PUBLIC_USE_MOCK=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=suporte@blackbelt.app
NEXT_PUBLIC_SUPPORT_PHONE=+55 11 99999-0000
NEXT_PUBLIC_BETA_MODE=true

# ── Supabase (required in production) ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# ── Payment Gateway ─────────────────────────────────
# Supported values: asaas | stripe | mock
PAYMENT_GATEWAY=mock
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email ────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
EMAIL_PROVIDER=mock
EMAIL_API_KEY=
EMAIL_FROM=noreply@blackbelt.app

# ── Monitoring (Sentry) ─────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=blackbelt
SENTRY_PROJECT=blackbelt

# ── Analytics (PostHog) ─────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Push Notifications ──────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
FCM_SERVER_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── WhatsApp Channel ────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=default

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=info
